---
import Layout from '../layouts/Layout.astro';
import DashboardLayout from '../components/Layout.jsx';
import Expenses from '../react-pages/Expenses.jsx';
import { AuthProvider } from '../context/AuthContext.jsx';
import { Toaster } from 'react-hot-toast';
---

<Layout title="نظام POS - Expenses">
	<AuthProvider client:only="react">
		<DashboardLayout client:only="react" currentPath="/expenses">
			<Expenses client:only="react" />
		</DashboardLayout>
	</AuthProvider>
	<Toaster client:only="react" />
</Layout>
