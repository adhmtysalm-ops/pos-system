---
import Layout from '../layouts/Layout.astro';
import DashboardLayout from '../components/Layout.jsx';
import Dashboard from '../react-pages/Dashboard.jsx';
import { AuthProvider } from '../context/AuthContext.jsx';
import { Toaster } from 'react-hot-toast';
---

<Layout title="نظام POS - لوحة التحكم">
	<AuthProvider client:only="react">
		<DashboardLayout client:only="react" currentPath="/">
			<Dashboard client:only="react" />
		</DashboardLayout>
	</AuthProvider>
	<Toaster client:only="react" />
</Layout>
