---
import Layout from '../layouts/Layout.astro';
import DashboardLayout from '../components/Layout.jsx';
import Products from '../react-pages/Products.jsx';
import { AuthProvider } from '../context/AuthContext.jsx';
import { Toaster } from 'react-hot-toast';
---

<Layout title="نظام POS - Products">
	<AuthProvider client:only="react">
		<DashboardLayout client:only="react" currentPath="/products">
			<Products client:only="react" />
		</DashboardLayout>
	</AuthProvider>
	<Toaster client:only="react" />
</Layout>
