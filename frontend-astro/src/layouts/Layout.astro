---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="نظام نقطة البيع الاحترافي - POS System" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<script is:inline>
			// Polyfills to prevent React/PeerJS crashes
			if (typeof global === 'undefined') {
				window.global = window;
			}
			if (typeof process === 'undefined') {
				window.process = { env: {} };
			}
		</script>
	</head>
	<body class="bg-gray-50 text-gray-900 font-cairo antialiased">
		<slot />
	</body>
</html>
